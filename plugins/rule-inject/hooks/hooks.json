{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_check_rules.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/post_track_reads.py"
          }
        ]
      }
    ]
  }
}
